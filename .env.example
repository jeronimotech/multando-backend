# Database
DATABASE_URL=postgresql+asyncpg://multando:changeme@postgres:5432/multando

# Redis
REDIS_URL=redis://redis:6379

# Security — CHANGE THIS
SECRET_KEY=your-secret-key-here

# Anthropic (for AI chatbot — get a key at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# MinIO / S3 evidence storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=multando-evidence
MINIO_USE_SSL=false

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth 2.0 Provider (Multando as authorization server for third-party apps)
OAUTH_CODE_EXPIRE_MINUTES=10
OAUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=production
DEBUG=false

# Federation — for self-hosted instances pushing anonymized data to the hub
# Set FEDERATION_ENABLED=true on self-hosted instances that should sync to multando.com
FEDERATION_ENABLED=false
FEDERATION_HUB_URL=https://api.multando.com
FEDERATION_API_KEY=           # Hub-issued API key for this instance
FEDERATION_INSTANCE_ID=       # UUID assigned when registering with the hub
FEDERATION_SYNC_INTERVAL_SECONDS=300

# Enterprise license (leave empty for community edition)
# Keys use prefix "mlt_ent_" and must be >= 20 chars
ENTERPRISE_LICENSE_KEY=

# White-label (enterprise only)
PLATFORM_NAME=Multando
PLATFORM_LOGO_URL=
PLATFORM_PRIMARY_COLOR=#EF4444
PLATFORM_SUPPORT_EMAIL=support@multando.com

# Bogota SDM (Secretaría Distrital de Movilidad) Google Form integration
# Set SDM_FORM_ENABLED=true to auto-submit verified Bogota reports to the SDM form
SDM_FORM_ENABLED=false
SDM_FORM_ID=1FAIpQLSeCG84Le6cCxegrj7ns_oA36t1GJe4sHKdblOYum_vuTOXYFQ
# Path to Google service account JSON file, or the JSON string itself
SDM_GOOGLE_SERVICE_ACCOUNT_JSON=
# Google Drive folder ID (shared with service account) for evidence uploads
SDM_GOOGLE_DRIVE_FOLDER_ID=

# PostgreSQL (used by docker-compose for the postgres container)
POSTGRES_PASSWORD=changeme
