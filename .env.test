# =============================================
# Multando API — Local Test Environment
# =============================================
# Uses docker-compose services (postgres, redis)
# Run: docker compose up -d postgres redis
# Then: APP_ENV=test uvicorn app.main:app --reload --env-file .env.test

# Application
APP_NAME=Multando API (Local)
APP_ENV=development
DEBUG=true

# Database (docker-compose postgres)
DATABASE_URL=postgresql+asyncpg://multando:multando_secret@localhost:5432/multando

# Redis (docker-compose redis)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=local-dev-secret-key-do-not-use-in-production-1234567890abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:5173"]

# Celery (docker-compose redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate Limiting (relaxed for local dev)
RATE_LIMIT_PER_MINUTE=300

# Chatbot
CHATBOT_API_KEY=dev-chatbot-key

# Storage (local — no S3/MinIO needed for testing)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=multando-evidence-local
STORAGE_BASE_URL=http://localhost:8000/static

# OAuth (leave empty for local, or fill with test credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Custodial Wallet
WALLET_MASTER_KEY=
WALLET_ENCRYPTION_PROVIDER=local

# Withdrawal Limits
WITHDRAWAL_DAILY_LIMIT=100
WITHDRAWAL_MONTHLY_LIMIT=1000
WITHDRAWAL_VERIFICATION_THRESHOLD=50
WITHDRAWAL_FEE=0.5
WITHDRAWAL_COOLDOWN_HOURS=24

# Solana (devnet — off-chain mode if keys empty)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=F43VFhBshFcZ3MLcdZHdGB1vMGjRUj4jwWhJ8gvTzEgG
SOLANA_MINT_ADDRESS=APNBE3fQ6aTgK1Lf8rtDBVzECNbM58ezYg3cEYbVG1Qs
SOLANA_REWARD_AUTHORITY_KEY=
SOLANA_NETWORK=devnet

# RECORD Integration (disabled locally)
TWOCAPTCHA_API_KEY=
RECORD_ENABLED=false

# Hot Wallet
HOT_WALLET_KEYPAIR_PATH=
HOT_WALLET_MIN_BALANCE=1000
